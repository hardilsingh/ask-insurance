# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://username:password@localhost:3306/ask_insurance?allowPublicKeyRetrieval=true"

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_ISSUER="ask-api"
JWT_AUDIENCE="insurance-app"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ── OTP ────────────────────────────────────────────────────────────────────────
OTP_EXPIRATION_MS=300000
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6
OTP_SALT_ROUNDS=10
# OTP_FIXED=123456   # Uncomment in dev to skip SMS and always accept this OTP

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,exp://localhost:8081,https://ask-api.bitopayments.com"

# ── Google OAuth (admin panel login) ──────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Add your admin panel URL as an Authorised JavaScript Origin
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ── Cloudflare R2 (file storage) ───────────────────────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="ask-insurance"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"

# ── Razorpay (payments) ────────────────────────────────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# ── Firebase Admin SDK (Phone Auth verification) ───────────────────────────────
# Get from: console.firebase.google.com → Project Settings → Service Accounts → Generate new private key
# Copy project_id, client_email, and private_key from the downloaded JSON file.
FIREBASE_PROJECT_ID="ask-in"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@ask-in.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
