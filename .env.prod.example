# ── Database ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_me_root
DB_NAME=ask_insurance
DB_USER=ask_user
DB_PASSWORD=change_me_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_AUDIENCE=ask-insurance-api

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your web/admin URLs, or * for dev)
ALLOWED_ORIGINS=https://your-web-domain.com,https://your-admin-domain.com
