{
  "name": "ask-insurance",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "web",
    "admin",
    "shared",
    "api"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:admin": "npm run dev --workspace=admin",
    "dev:api": "npm run dev --workspace=api",
    "dev:mobile": "cd mobile && npx expo start --clear",
    "dev": "npm run dev:web",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:admin\" \"npm run dev:api\"",
    "build:web": "npm run build --workspace=web",
    "build:admin": "npm run build --workspace=admin",
    "build:api": "npm run build --workspace=api",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
