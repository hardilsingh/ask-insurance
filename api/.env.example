# Database
DATABASE_URL="mysql://username:password@localhost:3306/ask_insurance"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ISSUER="ask-api"
JWT_AUDIENCE="insurance-app"
JWT_EXPIRES_IN="1d"

# OTP security
OTP_EXPIRATION_MS=300000
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6
OTP_SALT_ROUNDS=10

# Server
PORT=4000

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,exp://localhost:8081,https://ask-api.bitopayments.com"

# SMS Service (for production)
# SMS_API_KEY="your-sms-service-api-key"
# SMS_API_URL="https://api.sms-service.com/send"